{
  "name": "image-composer",
  "version": "0.6.0",
  "description": "Image Composer - 图片合成工具 (Electron 版)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.imagecomposer.app",
    "productName": "Image Composer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "renderer/icon.png"
    },
    "portable": {
      "artifactName": "ImageComposer_v${version}.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "bridge/**/*",
      "config.yaml",
      "credentials/**/*",
      "backgrounds/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bridge",
        "to": "bridge"
      },
      {
        "from": "credentials",
        "to": "credentials"
      },
      {
        "from": "config.yaml",
        "to": "config.yaml"
      }
    ]
  }
}
